# =========================
# Global
# =========================

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
*.sw?
*.log

# Environment files (keep templates tracked)
.env
.env.*
!.env.example

# Local databases
*.db
*.sqlite
*.sqlite3

# =========================
# VS Code / IDE
# =========================

# VS Code local metadata
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ / JetBrains
.idea/
*.iws
*.iml
*.ipr

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# =========================
# Frontend (Angular / npm)
# =========================

# Dependencies and package manager caches
node_modules/
frontend/node_modules/
frontend/.npm/
frontend/.pnpm-store/
frontend/.yarn/

# Build/cache outputs
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/.angular/
frontend/.sass-cache/

# Test and coverage
frontend/coverage/
frontend/.nyc_output/

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# =========================
# Backend (Java / Maven)
# =========================

# Build output
target/
backend/target/
backend/build/

# Allow target/build folders inside source if needed
!backend/**/src/main/**/target/
!backend/**/src/test/**/target/
!backend/**/src/main/**/build/
!backend/**/src/test/**/build/

# Maven wrapper binary
backend/.mvn/wrapper/maven-wrapper.jar

# Spring Tool Suite / Eclipse metadata
backend/.apt_generated
backend/.classpath
backend/.factorypath
backend/.project
backend/.settings/
backend/.springBeans
backend/.sts4-cache

# NetBeans metadata
backend/nbproject/private/
backend/nbbuild/
backend/dist/
backend/nbdist/
backend/.nb-gradle/

# IntelliJ metadata inside backend
backend/.idea/

# =========================
# Message Consumer (.NET / RabbitMQ)
# =========================

# .NET build output
bin/
obj/
message-consumer/bin/
message-consumer/obj/

# Local SQLite database generated by the message consumer
message-consumer/messages.db
message-consumer/*.db
message-consumer/*.sqlite
message-consumer/*.sqlite3

# User secrets / local config
message-consumer/appsettings.Development.json
message-consumer/*.user

# =========================
# RabbitMQ / Docker local files
# =========================

# Docker volumes or local RabbitMQ data, if created in the project folder
rabbitmq-data/
rabbitmq_logs/
rabbitmq_mnesia/

# =========================
# GitHub helper folders accidentally generated by tools
# =========================

.github/java-upgrade/